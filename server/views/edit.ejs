<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Page</title>
</head>

<body>
    <h1 class="head3">Edit Post</h1>
    <br>
    <h2>id: <%= post.id %>
    </h2>
    <br>
    <h2>
        <%=post.name%>
    </h2>
    <br>
    <form method="post" action="/posts/<%=post.id%>?_method=PATCH">
        <textarea name="post" rows="10" cols="20"><%=post.post%></textarea>
        <button>Update</button>
    </form>
</body>

</html>