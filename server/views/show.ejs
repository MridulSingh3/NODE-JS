<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <title>Show page</title>
</head>

<body>
    <h1 class="heading1">Show Page</h1>
    <% if(post) { %>
        <div class="container">
            <h3>id: <%= post.id %>
            </h3>
            <h2>name: <%= post.name %>
            </h2>
            <i>posts: <%= post.post %></i>
        </div>

        <% } else { %>
            <h2>Post not found</h2>
            <% } %>
</body>

</html>