<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Posts</title>
</head>

<body>
    <h1 class="heading1">Write new Post...</h1>
    <form method="POST" action="/chats">
        <label for="from">from</label>
        <input type="text" name="from" placeholder="who are you..">
        <br>
        <label for="msg">message</label>
        <textarea type="text" name="msg" placeholder="Write message" cols="20" rows="10"></textarea>
        <br>
        <label for="to">To</label>
        <input type="text" name="to" placeholder="Write sender name">
        <br>
        <button>Send</button>
    </form>
</body>

</html>